{
  "expo": {
    "name": "Aroha AI",
    "slug": "aroha-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "arohaai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "package": "com.aroha.ai",
      "adaptiveIcon": {
        "backgroundColor": "#0E7C7B"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
